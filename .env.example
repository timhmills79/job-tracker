# ── Anthropic ─────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Google OAuth ───────────────────────────────────────
# Create at: https://console.cloud.google.com
#   1. New project → APIs & Services → Credentials
#   2. Create OAuth 2.0 Client ID (Web application)
#   3. Add redirect URI: https://YOUR-APP.vercel.app/api/auth/callback
#      (also add http://localhost:3001/api/auth/callback for local dev)
#   4. Enable: Google Drive API, Google Sheets API
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Session ────────────────────────────────────────────
# Any random 32+ character string — used to sign session cookies
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ── App URL ────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash)
# Use http://localhost:5173 for local dev
VITE_APP_URL=https://your-app.vercel.app
